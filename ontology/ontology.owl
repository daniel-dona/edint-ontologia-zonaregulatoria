<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:dc="http://purl.org/dc/elements/1.1/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:terms="http://purl.org/dc/terms/"
   xmlns:vann="http://purl.org/vocab/vann/"
>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#FreeTradeZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Área del territorio aduanero de la Unión donde las mercancías no comunitarias se consideran no situadas en territorio aduanero.</rdfs:comment>
    <rdfs:comment xml:lang="en">Area of the Union customs territory where non-Community goods are considered not situated within customs territory.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona Franca</rdfs:label>
    <rdfs:label xml:lang="en">Free Trade Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#GreenSpaceZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Espacio libre, parque o área natural urbana sujeta a un régimen de protección urbanística que limita su edificabilidad y regula su uso público, vital para estrategias de mitigación climática y calidad del aire.</rdfs:comment>
    <rdfs:comment xml:lang="en">Open space, park, or urban natural area subject to a spatial planning protection regime that limits buildability and regulates public use, vital for climate mitigation and air quality strategies.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona Verde</rdfs:label>
    <rdfs:label xml:lang="en">Green Space Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RestrictedAccessZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Área urbana (como las Áreas de Prioridad Residencial - APR) donde el acceso de vehículos está limitado a residentes, transporte público o vehículos autorizados por motivos de fluidez, seguridad o capacidad viaria.</rdfs:comment>
    <rdfs:comment xml:lang="en">Urban area (such as Residential Priority Areas) where vehicle access is limited to residents, public transport, or authorized vehicles for reasons of traffic flow, safety, or road capacity.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Acceso Restringido</rdfs:label>
    <rdfs:label xml:lang="en">Restricted Access Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="es">tiene geometría</rdfs:label>
    <rdfs:label xml:lang="en">has geometry</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#HistoricalCenter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Área urbana de especial protección patrimonial donde se aplican restricciones estrictas de acceso, circulación y estacionamiento para preservar la trama histórica.</rdfs:comment>
    <rdfs:comment xml:lang="en">Urban area with special heritage protection where strict restrictions on access, circulation, and parking apply to preserve the historical fabric.</rdfs:comment>
    <rdfs:label xml:lang="es">Casco Histórico</rdfs:label>
    <rdfs:label xml:lang="en">Historical Center</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Área delimitada por normativas municipales para fomentar actividades comerciales o turísticas.</rdfs:comment>
    <rdfs:comment xml:lang="en">Area delimited by municipal regulations to promote commercial or tourist activities.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Interés Económico</rdfs:label>
    <rdfs:label xml:lang="en">Economic Interest Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#CommercialZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Área o eje urbano caracterizado por una alta densidad de actividad comercial y de servicios, frecuentemente amparada por normativas autonómicas de comercio bajo la figura de Zona Comercial Abierta (ZCA).</rdfs:comment>
    <rdfs:comment xml:lang="en">Urban area or axis characterized by a high density of commercial and service activity, frequently supported by regional commerce regulations under the figure of Open Commercial Zone.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona Comercial</rdfs:label>
    <rdfs:label xml:lang="en">Commercial Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#StreetVendingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Zona acotada para la modalidad de venta realizada fuera de establecimiento comercial permanente (mercadillos).</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone demarcated for sales conducted outside of permanent commercial establishments (street markets).</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Venta Ambulante</rdfs:label>
    <rdfs:label xml:lang="en">Street Vending Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfWithin"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
    <rdfs:comment xml:lang="es">Relaciona una zona regulatoria con el municipio administrativo al que pertenece.</rdfs:comment>
    <rdfs:comment xml:lang="en">Relates a regulated zone to the administrative municipality it belongs to.</rdfs:comment>
    <rdfs:label xml:lang="es">ubicado en municipio</rdfs:label>
    <rdfs:label xml:lang="en">located in municipality</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#asWKT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://www.opengis.net/ont/sf#Geometry"/>
    <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#wktLiteral"/>
    <rdfs:comment xml:lang="es">Representación de la geometría en formato Well-Known Text.</rdfs:comment>
    <rdfs:comment xml:lang="en">Geometry representation in Well-Known Text format.</rdfs:comment>
    <rdfs:label xml:lang="es">como WKT</rdfs:label>
    <rdfs:label xml:lang="en">as WKT</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#IndustrialZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Área delimitada por el planeamiento urbanístico (PGOU) y el Catastro destinada predominantemente a albergar actividades industriales, logísticas y empresariales.</rdfs:comment>
    <rdfs:comment xml:lang="en">Area delimited by urban planning and Cadastre intended predominantly to host industrial, logistics, and business activities.</rdfs:comment>
    <rdfs:label xml:lang="es">Polígono Industrial</rdfs:label>
    <rdfs:label xml:lang="en">Industrial Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#legalReference">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:comment xml:lang="es">Enlace al documento oficial (Boletín, Ordenanza) que establece la creación de la zona.</rdfs:comment>
    <rdfs:comment xml:lang="en">Link to the official document (Bulletin, Ordinance) establishing the zone.</rdfs:comment>
    <rdfs:label xml:lang="es">referencia legal</rdfs:label>
    <rdfs:label xml:lang="en">legal reference</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#ShortTermParkingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
    <rdfs:comment xml:lang="es">Zona destinada principalmente a usuarios visitantes con limitación temporal estricta y tarificación para favorecer la alta rotación.</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone intended primarily for visitors with strict time limits and fees to encourage high vehicle turnover.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Estacionamiento de Rotación</rdfs:label>
    <rdfs:label xml:lang="en">Short-term Parking Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#endDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="es">Fecha en la que la regulación de la zona deja de ser efectiva (derogación o fin de periodo).</rdfs:comment>
    <rdfs:comment xml:lang="en">Date when the zone regulation ceases to be effective.</rdfs:comment>
    <rdfs:label xml:lang="es">fecha de fin de vigor</rdfs:label>
    <rdfs:label xml:lang="en">end date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#LoadingUnloadingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
    <rdfs:comment xml:lang="es">Zona reservada exclusivamente para la parada técnica de vehículos profesionales dedicados a la Distribución Urbana de Mercancías (DUM).</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone reserved exclusively for the technical stop of professional vehicles dedicated to Urban Goods Distribution.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Carga y Descarga</rdfs:label>
    <rdfs:label xml:lang="en">Loading and Unloading Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
    <rdfs:subClassOf rdf:nodeID="n95ed579397fd4e8e999463f2894f840db1"/>
    <rdfs:subClassOf rdf:nodeID="n95ed579397fd4e8e999463f2894f840db2"/>
    <rdfs:comment xml:lang="es">Area a la que se aplica una regulacion o normativa particular</rdfs:comment>
    <rdfs:comment xml:lang="en">Area to which a particular regulation or policy applies</rdfs:comment>
    <rdfs:label xml:lang="es">Zona regulatoria</rdfs:label>
    <rdfs:label xml:lang="en">Regulated Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio_v0.5"/>
    <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero_v0.3"/>
    <dc:abstract xml:lang="es">Esta ontología tiene como propósito definir, categorizar y relacionar las Zonas Regulatorias en el contexto de la movilidad inteligente y la gestión urbana (Smart Cities). Se ha diseñado como una extensión modular de la ontología del Sector Público de España (esadm).</dc:abstract>
    <dc:abstract xml:lang="en">This ontology aims to define, categorize, and relate Regulatory Zones in the context of smart mobility and urban management (Smart Cities). It is designed as a modular extension of the Spanish Public Sector ontology (esadm).</dc:abstract>
    <dc:creator>OEG-UPM</dc:creator>
    <dc:title xml:lang="es">Ontología base de Zonas</dc:title>
    <dc:title xml:lang="en">Base Zoning Ontology</dc:title>
    <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-27</terms:issued>
    <vann:preferredNamespacePrefix>edintzone</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/common/zone#</vann:preferredNamespaceUri>
    <rdfs:comment xml:lang="es">Actualmente, existen vocabularios para divisiones administrativas (esadm) y geometrías (GeoSPARQL), pero existía un vacío semántico para representar entidades funcionales que se superponen a la trama urbana (ZBE, Carga y Descarga, etc...) sin responder a límites administrativos fijos. Esta ontología cubre dicho hueco.</rdfs:comment>
    <rdfs:comment xml:lang="en">Currently, vocabularies exist for administrative divisions (esadm) and geometries (GeoSPARQL), but there was a semantic gap for representing functional entities that overlay the urban grid (LEZ, Loading/Unloading, etc.) without adhering to fixed administrative boundaries. This ontology fills that gap.</rdfs:comment>
    <rdfs:label xml:lang="es">Ontología base de Zonas para el Caso de Uso de Movilidad Inteligente.</rdfs:label>
    <rdfs:label xml:lang="en">Base Zoning Ontology for Smart Mobility Use Case.</rdfs:label>
    <owl:versionInfo>0.1.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#startDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="es">Fecha a partir de la cual la regulación de la zona comienza a ser efectiva.</rdfs:comment>
    <rdfs:comment xml:lang="en">Date from which the zone regulation becomes effective.</rdfs:comment>
    <rdfs:label xml:lang="es">fecha de entrada en vigor</rdfs:label>
    <rdfs:label xml:lang="en">entry into force date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#scheduleDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="es">Descripción textual del horario de funcionamiento de la zona (ej. "Lunes a Viernes de 07:00 a 20:00").</rdfs:comment>
    <rdfs:comment xml:lang="en">Textual description of the zone's operating schedule (e.g., "Monday to Friday from 07:00 to 20:00").</rdfs:comment>
    <rdfs:label xml:lang="es">horario descriptivo</rdfs:label>
    <rdfs:label xml:lang="en">schedule description</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatorySandbox">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Espacio controlado de pruebas autorizado para la realización de ensayos de investigación con vehículos automatizados o nuevas formas de movilidad.</rdfs:comment>
    <rdfs:comment xml:lang="en">Controlled testing environment authorized for research trials with automated vehicles or new forms of mobility.</rdfs:comment>
    <rdfs:label xml:lang="es">Sandbox Regulatorio</rdfs:label>
    <rdfs:label xml:lang="en">Regulatory Sandbox</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/elements/1.1/abstract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Zona de la vía pública donde el estacionamiento está sujeto a regulación horaria, pago de tasas u otras restricciones.</rdfs:comment>
    <rdfs:comment xml:lang="en">Public road zone where parking is subject to time regulation, fee payment, or other restrictions.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Estacionamiento Regulado</rdfs:label>
    <rdfs:label xml:lang="en">Regulated Parking Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#LeisureZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Área con alta concentración de establecimientos de ocio y hostelería. Frecuentemente sujeta a regulaciones urbanísticas y medioambientales específicas, como las Zonas de Protección Acústica Especial (ZPAE).</rdfs:comment>
    <rdfs:comment xml:lang="en">Area with a high concentration of leisure and hospitality establishments. Frequently subject to specific urban and environmental regulations, such as Special Acoustic Protection Zones.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Ocio</rdfs:label>
    <rdfs:label xml:lang="en">Leisure Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#ParkAndRideZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
    <rdfs:comment xml:lang="es">Zona de estacionamiento estratégico situado en la periferia y conectado con redes de transporte público.</rdfs:comment>
    <rdfs:comment xml:lang="en">Strategic parking zone located on the periphery and connected to public transport networks.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Estacionamiento Disuasorio</rdfs:label>
    <rdfs:label xml:lang="en">Park and Ride Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/elements/1.1/description">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#managedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://www.w3.org/ns/org#Organization"/>
    <rdfs:comment xml:lang="es">Organización (pública o privada) encargada de la gestión y operación de la zona.</rdfs:comment>
    <rdfs:comment xml:lang="en">Organization (public or private) responsible for the management and operation of the zone.</rdfs:comment>
    <rdfs:label xml:lang="es">entidad gestora</rdfs:label>
    <rdfs:label xml:lang="en">managed by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#ReducedMobilityParkingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
    <rdfs:comment xml:lang="es">Zona de estacionamiento reservada legalmente para vehículos que transportan a Personas con Movilidad Reducida (PMR), regulada por normativas municipales y estatales de accesibilidad.</rdfs:comment>
    <rdfs:comment xml:lang="en">Parking zone legally reserved for vehicles transporting Persons with Reduced Mobility (PRM), regulated by municipal and national accessibility laws.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Estacionamiento PMR</rdfs:label>
    <rdfs:label xml:lang="en">Reduced Mobility Parking Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#HighTourismInfluxZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Zonas con gran afluencia turística donde se aplica plena libertad de apertura comercial en domingos y festivos.</rdfs:comment>
    <rdfs:comment xml:lang="en">Zones with high tourist influx where full freedom of commercial opening on Sundays and holidays applies.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Gran Afluencia Turística</rdfs:label>
    <rdfs:label xml:lang="en">High Tourism Influx Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#ResidentialParkingZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedParkingZone"/>
    <rdfs:comment xml:lang="es">Zona destinada prioritaria o exclusivamente al estacionamiento de vehículos de residentes empadronados.</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone intended primarily or exclusively for parking vehicles of registered residents.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Estacionamiento Residencial</rdfs:label>
    <rdfs:label xml:lang="en">Residential Parking Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#hasRegulatedZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <owl:inverseOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Propiedad inversa de 'ubicado'. Vincula un municipio con las zonas regulatorias que contiene.</rdfs:comment>
    <rdfs:comment xml:lang="en">Inverse property of 'locatedIn'. Links a municipality with the regulated zones it contains.</rdfs:comment>
    <rdfs:label xml:lang="es">tiene zona regulatoria</rdfs:label>
    <rdfs:label xml:lang="en">has regulated zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#PedestrianZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Vía o área reservada total o parcialmente para la circulación de peatones, con regulaciones estrictas de velocidad para los vehículos permitidos y prohibición general de estacionamiento.</rdfs:comment>
    <rdfs:comment xml:lang="en">Road or area reserved entirely or partially for pedestrian traffic, with strict speed regulations for permitted vehicles and a general prohibition on parking.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona Peatonal</rdfs:label>
    <rdfs:label xml:lang="en">Pedestrian Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#LowNoiseEmissionZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Zona definida por la administración donde se aplican restricciones de ruido y límites de emisión acústica para proteger la salud pública y el bienestar ciudadano.</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone defined by the administration where noise restrictions and acoustic emission limits apply to protect public health and citizen well-being.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Bajas Emisiones de Ruido</rdfs:label>
    <rdfs:label xml:lang="en">Low Noise Emission Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/ns/org#Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n95ed579397fd4e8e999463f2894f840db1">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    <owl:someValuesFrom rdf:resource="http://www.opengis.net/ont/sf#Geometry"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#LogisticsActivityZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Infraestructura especializada en actividades de transporte y logística. Definida legalmente como 'Centro de Transporte y Logística'.</rdfs:comment>
    <rdfs:comment xml:lang="en">Infrastructure specialized in transport and logistics activities. Legally defined as 'Transport and Logistics Center'.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Actividad Logística</rdfs:label>
    <rdfs:label xml:lang="en">Logistics Activity Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#ScienceTechnologyPark">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone"/>
    <rdfs:comment xml:lang="es">Espacio físico para el fomento de la I+D+i y la transferencia de conocimiento.</rdfs:comment>
    <rdfs:comment xml:lang="en">Physical space for promoting R&amp;D&amp;I and knowledge transfer.</rdfs:comment>
    <rdfs:label xml:lang="es">Parque Científico y Tecnológico</rdfs:label>
    <rdfs:label xml:lang="en">Science and Technology Park</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#LowEmissionZone">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:comment xml:lang="es">Zona definida por la administración donde se aplican restricciones de acceso, circulación y estacionamiento de vehículos con el objetivo de mejorar la calidad del aire.</rdfs:comment>
    <rdfs:comment xml:lang="en">Zone defined by the administration where restrictions on vehicle access, circulation, and parking apply to improve air quality.</rdfs:comment>
    <rdfs:label xml:lang="es">Zona de Bajas Emisiones</rdfs:label>
    <rdfs:label xml:lang="en">Low Emission Zone</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#wktLiteral">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/common/zone#composedOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone"/>
    <rdfs:range rdf:resource="http://dbpedia.org/ontology/GovernmentalAdministrativeRegion"/>
    <rdfs:range rdf:resource="http://www.geonames.org/ontology#Feature"/>
    <rdfs:comment xml:lang="es">Relación que permite definir una Zona Regulatoria mediante uno o más entidades administrativas (Via, Distrito, Municipio...).</rdfs:comment>
    <rdfs:comment xml:lang="en">Relationship that allows defining a Regulated Zone via one or more administrative entities (Street, District, Municipality...).</rdfs:comment>
    <rdfs:label xml:lang="es">compuesta por</rdfs:label>
    <rdfs:label xml:lang="en">composed of</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n95ed579397fd4e8e999463f2894f840db2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/common/zone#locatedIn"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.opengis.net/ont/geosparql#Feature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.opengis.net/ont/sf#Geometry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AnnotationProperty"/>
  </rdf:Description>
</rdf:RDF>

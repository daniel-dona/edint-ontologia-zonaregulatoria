# Obtener zonas de interés económico y su referencia legal
PREFIX edintzone: <http://vocab.linkeddata.es/datosabiertos/def/common/zone#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?zona ?tipoZona ?refLegal
WHERE {
    ?zona rdf:type ?tipoZona .
    ?tipoZona rdfs:subClassOf* edintzone:EconomicInterestZone .
    OPTIONAL { ?zona edintzone:legalReference ?refLegal . }
}
ORDER BY ?tipoZona ?zona

# Obtener zonas de interés económico con nombres y referencias legales
PREFIX edintzone: <http://vocab.linkeddata.es/datosabiertos/def/common/zone#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT DISTINCT ?zona ?nombreZona ?tipoZona ?nombreTipo ?refLegal
WHERE {
    ?zona rdf:type ?tipoZona .
    ?tipoZona rdfs:subClassOf* edintzone:EconomicInterestZone .
    OPTIONAL { ?zona rdfs:label ?nombreZona . }
    OPTIONAL { ?tipoZona rdfs:label ?nombreTipo . }
    OPTIONAL { ?zona edintzone:legalReference ?refLegal . }
}
ORDER BY ?nombreTipo ?nombreZona
